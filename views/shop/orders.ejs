<%- include('../includes/head.ejs') %>
    </head>

    <body>
        <%- include('../includes/navigation.ejs') %>
        <main>
            <% if(orders.length<=0){ %>
            <h1>Nothing there!</h1>
            <% } else { %>
                <ul>
                    <% orders.forEach(order=>{ %>
                        <li>
                            <h1># <%= order.id %></h1>
                            <ul>
                                <% order.products.forEach(product=>{

                                %>
                                <li><%= product.title %> - Quantity: <%= product.orderItem.quantity %></li> //because quantity stored in orderItem not in product
                                <% }) %>

                            </ul>



                        </li>
                    <% }) %>






                </ul>
            <% } %>
             
        </main>
        <%- include('../includes/end.ejs') %>